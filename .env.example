# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=reports_db
DB_USER=postgres
DB_PASSWORD=secret

# Email - SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password

# Email - SendGrid (alternative)
SENDGRID_API_KEY=SG.xxxxxxxxxxxx
EMAIL_FROM=reports@yourcompany.com
EMAIL_FROM_NAME=Report Bot

# Alert email for failures
ALERT_EMAIL=admin@yourcompany.com

# Email provider: smtp or sendgrid
EMAIL_PROVIDER=smtp

# Reports config directory
REPORTS_CONFIG_DIR=reports/config

# Output directory for generated reports
OUTPUT_DIR=output
